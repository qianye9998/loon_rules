# Custom direct rules
# Maintain this file manually.
# The daily sync task will deduplicate repeated rule lines.
# Example:
DOMAIN-KEYWORD,pzds
DOMAIN-KEYWORD,nfgood
DOMAIN-SUFFIX,pgyer.com,DIRECT
DOMAIN-SUFFIX,pgyer.cc,DIRECT
DOMAIN-SUFFIX,tracup.com,DIRECT
DOMAIN-SUFFIX,frontjs.com,DIRECT
IP-CIDR,1.1.1.1/32,PROXY,no-resolve
IP-CIDR,8.8.8.8/32,PROXY,no-resolve
